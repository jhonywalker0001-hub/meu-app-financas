<Dashboard>:
    orientation: "vertical"
    padding: "16dp"
    spacing: "10dp"

    # AREA DO SALDO
    MDCard:
        orientation: "vertical"
        size_hint: 1, None
        height: "180dp"
        padding: "20dp"
        radius: [20, 20, 20, 20]
        md_bg_color: 0.15, 0.15, 0.25, 1
        elevation: 4

        MDLabel:
            text: "Saldo Total"
            theme_text_color: "Hint"
            font_style: "Subtitle1"
            halign: "center"

        MDLabel:
            id: label_saldo
            text: "R$ 0,00"
            font_style: "H4"
            bold: True
            halign: "center"
            theme_text_color: "Custom"
            text_color: 1, 1, 1, 1

        MDBoxLayout:
            orientation: "horizontal"
            spacing: "10dp"
            size_hint_y: None
            height: "40dp"

            MDLabel:
                id: label_receitas
                text: "↑ R$ 0,00"
                theme_text_color: "Custom"
                text_color: 0, 1, 0.5, 1
                halign: "center"

            MDLabel:
                id: label_despesas
                text: "↓ R$ 0,00"
                theme_text_color: "Custom"
                text_color: 1, 0.3, 0.3, 1
                halign: "center"

    MDLabel:
        text: "Últimas Transações"
        font_style: "H6"
        bold: True
        size_hint_y: None
        height: "40dp"

    # LISTA DE TRANSAÇÕES
    ScrollView:
        do_scroll_x: False
        MDList:
            id: container_lista
